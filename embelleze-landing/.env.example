# Configurações do Redis (Railway ou Local)
REDIS_URL="redis://localhost:6379"

# Configurações de Ambiente
NODE_ENV="development"
PORT=4321
HOST="0.0.0.0"
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Configurações da Z-API (WhatsApp)
ZAPI_INSTANCE_ID="sua_instancia_aqui"
ZAPI_TOKEN="seu_token_aqui"
ZAPI_CLIENT_TOKEN="seu_client_token_aqui"

# Configurações da Bella (Azure OpenAI)
AZURE_OPENAI_ENDPOINT="seu_endpoint_azure_aqui"
AZURE_OPENAI_API_KEY="sua_chave_api_aqui"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o"
BELLA_MODEL="gpt-4o"
BELLA_MAX_TOKENS="800"
BELLA_TEMPERATURE="0.7"

# Google Tag (gtag.js) — Google Ads
PUBLIC_GTAG_ID="AW-18004058795"

# Meta Pixel — preencher após acesso do cliente
PUBLIC_META_PIXEL_ID="pendente"

# Google Maps API Key — necessária para embed no /mapa
PUBLIC_GOOGLE_MAPS_KEY="pendente"

# Probeltec CRM
PROBELTEC_API_URL="https://api.probeltec.com/api/v1"
PROBELTEC_AUTH_URL="https://api-auth.probeltec.com/v1"
PROBELTEC_EMAIL="email@institutoembelleze.com"
PROBELTEC_PASSWORD="sua_senha_aqui"
# idOrigin padrão para leads WhatsApp Bella = 7 (Instagram WhatsApp)
PROBELTEC_DEFAULT_ORIGIN_ID="7"
PROBELTEC_DEFAULT_ORIGIN_NAME="Instagram WhatsApp"
# idFunnel padrão = 1 (SDR)
PROBELTEC_DEFAULT_FUNNEL_ID="1"

# ── FlowPay Gateway ────────────────────────────────────────────────────────
# Bearer token enviado pelo FlowPay no header Authorization dos webhooks.
# Configurar no painel FlowPay: Settings > Webhooks > Secret Token
# URL do webhook: https://embelleze-bella.online/api/payment/flowpay/webhook
FLOWPAY_WEBHOOK_SECRET="seu_secret_aqui"
