# Configurações do Redis (Railway ou Local)
REDIS_URL="redis://localhost:6379"

# Configurações de Ambiente
NODE_ENV="development"
PORT=4321
HOST="0.0.0.0"
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Configurações da Z-API (WhatsApp)
ZAPI_INSTANCE_ID="sua_instancia_aqui"
ZAPI_TOKEN="seu_token_aqui"
ZAPI_CLIENT_TOKEN="seu_client_token_aqui"

# Configurações da Bella (Azure OpenAI)
AZURE_OPENAI_ENDPOINT="seu_endpoint_azure_aqui"
AZURE_OPENAI_API_KEY="sua_chave_api_aqui"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o"
BELLA_MODEL="gpt-4o"
BELLA_MAX_TOKENS="800"
BELLA_TEMPERATURE="0.7"

# Google Tag (gtag.js) — Google Ads
PUBLIC_GTAG_ID="AW-18004058795"

# Meta Pixel — preencher após acesso do cliente
PUBLIC_META_PIXEL_ID="pendente"

# Google Maps API Key — necessária para embed no /mapa
PUBLIC_GOOGLE_MAPS_KEY="pendente"
