---
import { getWhatsAppLink } from '../lib/whatsapp';

const ctaLink = getWhatsAppLink({ origin: 'final-cta' });
---

<section class="final-cta">
  <!-- Camadas de fundo -->
  <div class="final-cta__bg" aria-hidden="true"></div>
  <div class="final-cta__noise" aria-hidden="true"></div>

  <!-- Decorativos -->
  <span class="final-cta__star final-cta__star--1" aria-hidden="true">✦</span>
  <span class="final-cta__star final-cta__star--2" aria-hidden="true">✦</span>
  <span class="final-cta__star final-cta__star--3" aria-hidden="true">✦</span>

  <div class="final-cta__inner">

    <!-- Bloco negativo -->
    <div class="final-cta__contrast-block">
      <p class="final-cta__lead">Daqui a alguns meses, tudo pode continuar igual.</p>
    </div>

    <!-- Divider visual -->
    <div class="final-cta__divider" aria-hidden="true">
      <span class="final-cta__divider-line"></span>
      <span class="final-cta__divider-or">ou</span>
      <span class="final-cta__divider-line"></span>
    </div>

    <!-- Bloco positivo -->
    <h2 class="final-cta__title">
      Você pode estar começando<br class="final-cta__br" />
      <em class="final-cta__em">uma nova profissão.</em>
    </h2>

    <p class="final-cta__sub">A decisão é sua. A Bella está aqui para ajudar agora.</p>

    <div class="final-cta__action">
      <a href={ctaLink} class="final-cta__btn" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Quero começar — falar com a Bella
      </a>
      <p class="final-cta__note">Resposta em minutos · sem compromisso</p>
    </div>

  </div>
</section>

<style>
  .final-cta {
    color: #fff;
    padding: clamp(5rem, 12vw, 8rem) var(--spacing-sm);
    text-align: center;
    position: relative;
    overflow: hidden;
    background: #0d0416;
  }

  /* Gradiente de fundo rico */
  .final-cta__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196, 76, 51, 0.6) 0%, transparent 65%),
      radial-gradient(ellipse 60% 40% at 20% 100%, rgba(140, 40, 20, 0.4) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 50%, rgba(222, 88, 61, 0.2) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Textura noise */
  .final-cta__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
  }

  /* Estrelas decorativas */
  .final-cta__star {
    position: absolute;
    color: rgba(255, 255, 255, 0.15);
    font-size: 1.5rem;
    pointer-events: none;
    animation: twinkle 4s ease-in-out infinite;
  }
  .final-cta__star--1 { top: 12%; left: 8%; animation-delay: 0s; }
  .final-cta__star--2 { top: 20%; right: 10%; animation-delay: 1.5s; font-size: 1rem; }
  .final-cta__star--3 { bottom: 20%; left: 15%; animation-delay: 3s; font-size: 0.875rem; }

  @keyframes twinkle {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.2); }
  }

  /* Inner */
  .final-cta__inner {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Bloco de contraste (frase negativa) */
  .final-cta__contrast-block {
    display: inline-block;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 1rem 1.5rem;
    margin-bottom: 0;
    backdrop-filter: blur(8px);
  }

  .final-cta__lead {
    font-size: clamp(0.9375rem, 2.5vw, 1.0625rem);
    opacity: 0.75;
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  /* Divisor ou */
  .final-cta__divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
  }

  .final-cta__divider-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  .final-cta__divider-or {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* Título principal */
  .final-cta__title {
    font-size: clamp(2.25rem, 7vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .final-cta__br { display: block; }

  .final-cta__em {
    font-style: normal;
    color: #ff8a65;
  }

  .final-cta__sub {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  /* Bloco de ação */
  .final-cta__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  /* Botão branco */
  .final-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    max-width: 420px;
    padding: 20px 32px;
    background: #fff;
    color: #1a0830;
    border-radius: 18px;
    font-weight: 800;
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    -webkit-tap-highlight-color: transparent;
  }

  .final-cta__btn svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    fill: #25d366;
  }

  .final-cta__btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 28px 60px rgba(0, 0, 0, 0.4);
  }

  .final-cta__btn:active {
    transform: scale(0.98);
  }

  .final-cta__note {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
  }
</style>
