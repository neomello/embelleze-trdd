---
import courses from '../content/courses.json';
import CourseIcon from '../components/CourseIcon.astro';

const categories = [
  { name: 'Cabelo',   iconId: 'lucide:scissors',  color: '#a78bfa', desc: 'Corte, coloração e tratamentos' },
  { name: 'Unhas',    iconId: 'lucide:sparkles',   color: '#fb923c', desc: 'Manicure, gel e alongamento' },
  { name: 'Estética', iconId: 'lucide:star',        color: '#34d399', desc: 'Design facial e corporal' },
];

const countByCategory = Object.fromEntries(
  categories.map(c => [c.name, courses.filter(course => course.category === c.name).length])
);
---

<section class="area-picker" id="cursos">
  <div class="area-picker__bg" aria-hidden="true"></div>

  <div class="area-picker__container">
    <header class="area-picker__header">
      <span class="area-picker__eyebrow">Formações Profissionais</span>
      <h2 class="area-picker__title">Qual é a sua área?</h2>
      <p class="area-picker__subtitle">
        Toque na área e veja os cursos disponíveis agora.
      </p>
    </header>

    <div class="area-picker__grid">
      {categories.map(cat => (
        <a
          href={`/cursos?area=${cat.name}`}
          class="area-card"
          data-category={cat.name}
          style={`--cat-color: ${cat.color};`}
        >
          <div class="area-card__check" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="area-card__icon">
            <CourseIcon iconId={cat.iconId} className="area-card__icon-svg" />
          </div>
          <div class="area-card__body">
            <strong class="area-card__name">{cat.name}</strong>
            <span class="area-card__desc">{cat.desc}</span>
          </div>
          <div class="area-card__count">
            <span class="area-card__count-num">{countByCategory[cat.name]}</span>
            <span class="area-card__count-label">cursos</span>
          </div>
        </a>
      ))}
    </div>

    <div class="area-picker__footer">
      <a href="/cursos" class="area-picker__cta">
        Ver todas as formações
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .area-picker {
    scroll-margin-top: 80px;
    padding: clamp(5rem, 12vw, 9rem) var(--spacing-sm);
    background: #0a0212;
    position: relative;
    overflow: hidden;
  }

  .area-picker__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(95, 48, 128, 0.12) 0%, transparent 55%),
      radial-gradient(circle at 80% 50%, rgba(222, 88, 61, 0.08) 0%, transparent 55%);
    pointer-events: none;
  }

  .area-picker__container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .area-picker__header {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .area-picker__eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-orange);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  .area-picker__title {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }

  .area-picker__subtitle {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Cards ── */
  .area-picker__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 600px) {
    .area-picker__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  .area-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1.5px solid rgba(255, 255, 255, 0.07);
    border-radius: 20px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s ease,
                border-color 0.3s ease,
                box-shadow 0.35s ease;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 600px) {
    .area-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.75rem;
      border-radius: 24px;
      gap: 1.25rem;
    }
  }

  .area-card:active {
    transform: scale(0.96);
  }

  .area-card:hover,
  .area-card:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--cat-color);
    box-shadow: 0 0 30px color-mix(in srgb, var(--cat-color) 20%, transparent);
    transform: translateY(-4px);
  }

  /* Check badge (aparece no hover) */
  .area-card__check {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--cat-color);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .area-card__check svg {
    width: 12px;
    height: 12px;
    stroke: #000;
  }

  .area-card:hover .area-card__check,
  .area-card:focus-visible .area-card__check {
    opacity: 1;
    transform: scale(1);
  }

  /* Icon */
  .area-card__icon {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--cat-color) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--cat-color);
    transition: background 0.3s ease;
  }

  .area-card:hover .area-card__icon {
    background: color-mix(in srgb, var(--cat-color) 20%, transparent);
  }

  .area-card__icon-svg {
    width: 22px;
    height: 22px;
    stroke-width: 2;
  }

  /* Body */
  .area-card__body {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .area-card__name {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }

  .area-card__desc {
    display: block;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 600px) {
    .area-card__desc { white-space: normal; }
  }

  /* Count badge */
  .area-card__count {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--cat-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--cat-color) 25%, transparent);
    border-radius: 12px;
    padding: 0.4rem 0.75rem;
    transition: background 0.3s ease;
  }

  .area-card:hover .area-card__count {
    background: color-mix(in srgb, var(--cat-color) 20%, transparent);
  }

  @media (min-width: 600px) {
    .area-card__count {
      position: absolute;
      bottom: 1.75rem;
      right: 1.75rem;
    }
  }

  .area-card__count-num {
    font-size: 1.125rem;
    font-weight: 900;
    color: var(--cat-color);
    line-height: 1;
  }

  .area-card__count-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* CTA */
  .area-picker__footer {
    display: flex;
    justify-content: center;
  }

  .area-picker__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .area-picker__cta svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .area-picker__cta:hover {
    background: #fff;
    border-color: #fff;
    color: #12071f;
    transform: translateY(-2px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .area-picker__cta:hover svg {
    transform: translateX(4px);
  }
</style>
