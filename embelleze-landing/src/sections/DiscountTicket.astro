---
import CountdownTimer from '../components/CountdownTimer.astro';
---

<section class="ticket">
  <div class="ticket__inner">
    <h2 class="ticket__title">Seu código de reserva</h2>
    <p class="ticket__sub">Use este código ao falar com a Bella e garanta prioridade na matrícula.</p>
    <div class="ticket__code" id="ticketCode">Gerando...</div>
    <CountdownTimer minutes={15} />
    <a href="https://wa.me/5562984836550" id="ticketCTA" class="btn btn--primary">Usar código no WhatsApp</a>
  </div>
</section>

<script>
  import { generateTicket } from '../lib/discount-code';
  import { getWhatsAppLink } from '../lib/whatsapp';
  import { track, Events } from '../lib/tracking';

  const codeEl = document.getElementById('ticketCode');
  const ctaEl = document.getElementById('ticketCTA') as HTMLAnchorElement | null;

  const ticket = generateTicket();
  if (codeEl) codeEl.textContent = ticket;

  if (ctaEl) {
    ctaEl.href = getWhatsAppLink({ ticket, origin: 'discount-ticket' });
  }

  track({ event: Events.GENERATE_DISCOUNT_TICKET, ticket });
</script>

<style>
  .ticket {
    background: #fff8f6;
    padding: var(--spacing-xl) var(--spacing-sm);
    text-align: center;
  }
  .ticket__inner { max-width: 480px; margin: 0 auto; }
  .ticket__title {
    font-size: var(--font-size-xl);
    color: var(--color-purple);
    margin-bottom: var(--spacing-xs);
  }
  .ticket__sub {
    margin-bottom: var(--spacing-md);
    color: #555;
  }
  #ticketCTA {
    display: inline-block;
    background: var(--color-orange);
    color: var(--color-white);
    border: 2px solid var(--color-orange);
    border-radius: var(--radius-md);
    padding: 12px 24px;
    font-weight: 700;
    font-size: var(--font-size-base);
    text-decoration: none;
    cursor: pointer;
  }
  .ticket__code {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-orange);
    background: var(--color-white);
    border: 2px dashed var(--color-orange);
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) var(--spacing-md);
    margin-bottom: var(--spacing-md);
    user-select: all;
  }
</style>
