---
import CourseCard from '../components/CourseCard.astro';
import courses from '../content/courses.json';
---

<section class="courses" id="cursos">
  <!-- Efeitos de Fundo -->
  <div class="courses__glow courses__glow--1"></div>
  <div class="courses__glow courses__glow--2"></div>
  
  <div class="courses__container">
    <header class="courses__header">
      <div class="courses__badge">Formação de Elite</div>
      <h2 class="courses__title">Especialize-se e Transforme sua Carreira</h2>
      <p class="courses__subtitle">
        Escolha sua especialização. Toque no curso para ver detalhes e falar diretamente com a Bella.
      </p>
    </header>

    <div class="courses__filter">
      <button class="courses__filter-btn active" data-filter="all">Todos</button>
      <button class="courses__filter-btn" data-filter="Cabelo">Cabelo</button>
      <button class="courses__filter-btn" data-filter="Unhas">Unhas</button>
      <button class="courses__filter-btn" data-filter="Estética">Estética</button>
    </div>

    <div class="courses__grid" id="courses-grid">
      {courses.map(course => (
        <CourseCard
          id={course.id}
          name={course.name}
          category={course.category}
          description={course.description}
          ctaText={course.ctaText}
          iconId={course.iconId}
          duration={course.duration}
          frequency={course.frequency}
          schedule={course.schedule}
          confirmed={course.confirmed}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll('.courses__filter-btn');
  const cards = document.querySelectorAll('.course-card') as NodeListOf<HTMLElement>;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      // Update UI
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter Cards
      cards.forEach(card => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          card.style.display = 'flex';
          setTimeout(() => card.style.opacity = '1', 10);
        } else {
          card.style.opacity = '0';
          setTimeout(() => card.style.display = 'none', 300);
        }
      });
    });
  });
</script>

<style>
  .courses {
    padding: clamp(6rem, 12vw, 10rem) var(--spacing-sm);
    background: #0d0416;
    position: relative;
    overflow: hidden;
  }

  .courses__glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
    z-index: 1;
  }

  .courses__glow--1 {
    top: -10%;
    right: -10%;
    background: var(--color-purple);
  }

  .courses__glow--2 {
    bottom: -10%;
    left: -10%;
    background: var(--color-orange);
  }

  .courses__container {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .courses__header {
    text-align: center;
    margin-bottom: clamp(4rem, 8vw, 6rem);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .courses__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
    border: 1px solid rgba(222, 88, 61, 0.3);
    padding: 8px 16px;
    border-radius: 100px;
    background: rgba(222, 88, 61, 0.05);
    margin-bottom: 1.5rem;
  }

  .courses__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
  }

  .courses__subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }

  .courses__filter {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .courses__filter-btn {
    padding: 12px 24px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .courses__filter-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .courses__filter-btn.active {
    background: #fff;
    color: #12071f;
    border-color: #fff;
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.2);
  }

  .courses__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    width: 100%;
    transition: opacity 0.3s ease;
  }

  .course-card {
    width: 100% !important; /* Forçar preenchimento total da coluna */
    margin: 0 !important;
  }

  @media (min-width: 768px) {
    .courses__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .courses__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }

  @media (max-width: 600px) {
    .courses__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }
  }

  @media (max-width: 400px) {
    /* Em telas muito pequenas, se 2 colunas ficarem apertadas, podemos manter 1 ou reduzir o gap */
    .courses__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 6px;
    }
  }
</style>
