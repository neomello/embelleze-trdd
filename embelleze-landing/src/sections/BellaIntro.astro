---
import { Image } from 'astro:assets';
import { getWhatsAppLink } from '../lib/whatsapp';
import CourseIcon from '../components/CourseIcon.astro';
import bellaPhoto from '../assets/bella/bella-front.png';

const ctaLink = getWhatsAppLink({ origin: 'bella-intro' });
---

<section class="bella">
  <div class="bella__container">
    <div class="bella__card">
      <div class="bella__grid">
        <!-- Photo Side -->
        <div class="bella__visual">
          <div class="bella__photo-wrapper">
             <div class="bella__photo-glow"></div>
             <Image src={bellaPhoto} alt="Bella" class="bella__photo" />
             <div class="bella__status">
               <span class="bella__dot"></span>
               Consultora Oficial
             </div>
          </div>
        </div>

        <!-- Content Side -->
        <div class="bella__content">
          <div class="bella__header">
            <span class="bella__tag">Atendimento Inteligente</span>
            <h2 class="bella__title">
              Oi, eu sou a Bella 
              <div class="bella__wave-container">
                <CourseIcon iconId="lucide:hand" className="bella__wave" />
              </div>
            </h2>
          </div>

          <div class="bella__body">
            <p class="bella__description">
              Sou a consultora aqui do Instituto Embelleze de Trindade - GO. Minha missão é ajudar você a encontrar o curso perfeito e iniciar sua nova realidade <span class="bella__highlight">vamos falar de sonhos?</span>
            </p>
            <p class="bella__status-text">Te aguardo no whatsapp, sem perguntinhas de robô... rsrs</p>
          </div>

          <div class="bella__footer">
            <a href={ctaLink} class="bella__btn">
              <svg class="bella__btn-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766 0-3.18-2.587-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.941-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217s.231.001.332.005c.109.004.258-.041.404.308.159.386.542 1.32.588 1.416.046.096.077.208.014.335-.062.126-.093.204-.188.312-.095.108-.19.242-.271.327-.09.094-.184.197-.079.377.105.18.468.771.999 1.242.685.61 1.262.799 1.443.889.181.09.289.077.397-.049.109-.126.463-.537.586-.719.123-.181.246-.154.414-.093.167.061 1.062.501 1.247.593.185.092.308.138.354.217.046.079.046.458-.098.863z"/>
              </svg>
              Chamar Bella agora
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bella {
    padding: clamp(4rem, 10vw, 8rem) var(--spacing-sm);
    background: #0d0416;
    position: relative;
    overflow: hidden;
  }

  .bella__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .bella__card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 48px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.4);
  }

  .bella__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  /* Visual Side */
  .bella__visual {
    background: linear-gradient(135deg, rgba(95, 48, 128, 0.2), rgba(222, 88, 61, 0.1));
    display: flex;
    align-items: flex-end;
    justify-content: center;
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .bella__photo-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .bella__photo-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--color-orange);
    filter: blur(100px);
    opacity: 0.2;
    bottom: -50px;
  }

  .bella__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
  }

  .bella__status {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 10px 20px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 3;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }

  .bella__dot {
    width: 8px;
    height: 8px;
    background: #25d366;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(37, 211, 102, 0.6);
  }

  /* Content Side */
  .bella__content {
    padding: clamp(2.5rem, 8vw, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
  }

  .bella__tag {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-orange);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    display: block;
    margin-bottom: 1rem;
  }

  .bella__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.04em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bella__wave-container {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  :global(.bella__wave) {
    width: 32px !important;
    height: 32px !important;
    color: var(--color-orange);
    animation: bella-wave 2s infinite ease-in-out;
  }

  @keyframes bella-wave {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(20deg); }
  }

  .bella__description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .bella__highlight {
    color: #fff;
    font-weight: 700;
  }

  .bella__status-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .bella__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 40px;
    background: #25d366;
    color: #fff;
    border-radius: 20px;
    font-weight: 800;
    font-size: 1.125rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 15px 40px rgba(37, 211, 102, 0.2);
  }

  .bella__btn:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 25px 60px rgba(37, 211, 102, 0.4);
    background: #20ba59;
  }

  .bella__btn-icon {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 900px) {
    .bella__grid { grid-template-columns: 1fr; }
    .bella__visual { height: 350px; order: 2; }
    .bella__content { padding: 3.5rem 2rem; order: 1; text-align: center; }
    .bella__title { justify-content: center; }
    .bella__btn { width: 100%; justify-content: center; }
  }

  /* ── Efeitos de Entrada Suaves ── */
  .bella__visual, .bella__content {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bella__visual.visible, .bella__content.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Delay leve para o conteúdo para dar efeito cascata */
  .bella__content.visible { transition-delay: 0.2s; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.bella__visual, .bella__content').forEach(el => observer.observe(el));
</script>
