---
import { Image } from 'astro:assets';
import faqs from '../content/faqs.json';
import bellaAvatar from '../assets/bella/bella-front.png';
import { getWhatsAppLink } from '../lib/whatsapp';

const faqCtaLink = getWhatsAppLink({ origin: 'faq' });
---

<section class="faq" id="faq">
  <div class="faq__bg" aria-hidden="true"></div>

  <div class="faq__container">
    <header class="faq__header">
      <span class="faq__eyebrow">Tire suas dúvidas</span>
      <h2 class="faq__title">Dúvidas Frequentes</h2>
    </header>

    <!-- Chat window -->
    <div class="chat-window">

      <!-- Header do chat (estilo WhatsApp) -->
      <div class="chat-header">
        <div class="chat-header__avatar">
          <Image src={bellaAvatar} alt="Bella" class="chat-header__avatar-img" />
          <span class="chat-header__status-dot" aria-hidden="true"></span>
        </div>
        <div class="chat-header__info">
          <span class="chat-header__name">Bella — Instituto Embelleze</span>
          <span class="chat-header__status">Online agora</span>
        </div>
        <div class="chat-header__icons" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.45 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.46 5.46l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
        </div>
      </div>

      <!-- Mensagens -->
      <div class="chat-body" id="chat-body">

        <!-- Data separador -->
        <div class="chat-date">Hoje</div>

        {faqs.map((faq, i) => (
          <div class="chat-pair" data-index={i}>
            <!-- Pergunta (usuário — direita) -->
            <div class="chat-msg chat-msg--out">
              <div class="chat-bubble chat-bubble--out">
                <p>{faq.question}</p>
                <span class="chat-meta">
                  {String(9 + i).padStart(2,'0')}:{String(i * 7).padStart(2,'0')}
                  <svg class="chat-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m1 12 6 6L23 5"/><path d="m8 12 6 6"/></svg>
                </span>
              </div>
            </div>

            <!-- Typing indicator (aparece antes da resposta) -->
            <div class="chat-msg chat-msg--in chat-typing" id={`typing-${i}`}>
              <div class="chat-avatar-wrap">
                <div class="chat-avatar">
                  <Image src={bellaAvatar} alt="Bella" class="chat-avatar__img" />
                </div>
              </div>
              <div class="chat-bubble chat-bubble--typing">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
              </div>
            </div>

            <!-- Resposta (Bella — esquerda) -->
            <div class="chat-msg chat-msg--in chat-answer" id={`answer-${i}`}>
              <div class="chat-avatar-wrap">
                <div class="chat-avatar">
                  <Image src={bellaAvatar} alt="Bella" class="chat-avatar__img" />
                </div>
              </div>
              <div class="chat-bubble chat-bubble--in">
                <p>{faq.answer}</p>
                <span class="chat-meta chat-meta--in">
                  {String(9 + i).padStart(2,'0')}:{String(i * 7 + 2).padStart(2,'0')}
                </span>
              </div>
            </div>
          </div>
        ))}

      </div>

      <!-- Input decorativo (agora leva para o WhatsApp) -->
      <div class="chat-input-bar">
        <a href={faqCtaLink} target="_blank" rel="noopener" class="chat-input-fake">
          <span>Envie uma mensagem...</span>
        </a>
        <a
          href={faqCtaLink}
          class="chat-send-btn"
          target="_blank"
          rel="noopener"
          aria-label="Abrir WhatsApp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Sons reais do iOS (arquivos gravados do iPhone) ─────────────────────
  // Pré-carregados para evitar delay no primeiro play.
  // HTMLAudioElement não precisa de AudioContext — funciona após qualquer interação.
  const sndSent     = new Audio('/sounds/sms-sent.mp3');
  const sndReceived = new Audio('/sounds/sms-received.mp3');
  sndSent.preload     = 'auto';
  sndReceived.preload = 'auto';

  function playSendSound() {
    sndSent.currentTime = 0;
    sndSent.play().catch(() => {});
  }

  function playNotification() {
    sndReceived.currentTime = 0;
    sndReceived.play().catch(() => {});
  }

  // ── Lógica do chat ───────────────────────────────────────────────────────
  const pairs = document.querySelectorAll('.chat-pair');
  let started = false;

  function sleep(ms: number) {
    return new Promise<void>(r => setTimeout(r, ms));
  }

  async function revealChat() {
    if (started) return;
    started = true;

    for (let i = 0; i < pairs.length; i++) {
      const pair = pairs[i] as HTMLElement;
      const typing = document.getElementById(`typing-${i}`)!;
      const answer  = document.getElementById(`answer-${i}`)!;

      // Pergunta do usuário + som de envio
      const q = pair.querySelector('.chat-msg--out') as HTMLElement;
      q.classList.add('visible');
      playSendSound();
      await sleep(600);

      // Typing indicator da Bella
      typing.classList.add('visible');
      await sleep(1800);

      // Resposta da Bella + som de recebimento
      typing.classList.remove('visible');
      typing.style.display = 'none';
      answer.classList.add('visible');
      playNotification();

      if (i < pairs.length - 1) await sleep(900);
    }
  }

  const observer = new IntersectionObserver(
    entries => {
      if (entries[0].isIntersecting) {
        revealChat();
        observer.disconnect();
      }
    },
    { threshold: 0.2 }
  );

  const chatBody = document.getElementById('chat-body');
  if (chatBody) observer.observe(chatBody);
</script>

<style>
  /* ── Seção ── */
  .faq {
    padding: clamp(5rem, 10vw, 8rem) var(--spacing-sm);
    background: #12071f;
    position: relative;
    overflow: hidden;
  }

  .faq__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(95, 48, 128, 0.2), transparent 70%);
    pointer-events: none;
  }

  .faq__container {
    max-width: 520px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .faq__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .faq__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-orange);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .faq__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  /* ── Chat Window ── */
  .chat-window {
    background: #1a0d2e;
    border-radius: 28px;
    overflow: hidden;
    box-shadow:
      0 40px 100px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.06);
  }

  /* ── Chat Header ── */
  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .chat-header__avatar {
    position: relative;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(95,48,128,0.3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chat-header__avatar-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center top;
  }

  .chat-header__status-dot {
    position: absolute;
    bottom: 1px;
    right: 1px;
    width: 10px;
    height: 10px;
    background: #25d366;
    border-radius: 50%;
    border: 2px solid #1a0d2e;
  }

  .chat-header__info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .chat-header__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chat-header__status {
    font-size: 0.75rem;
    color: #25d366;
    font-weight: 500;
  }

  .chat-header__icons {
    display: flex;
    gap: 12px;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }

  /* ── Chat Body ── */
  .chat-body {
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 300px;
    background:
      radial-gradient(circle at 20% 80%, rgba(95,48,128,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(222,88,61,0.06) 0%, transparent 50%),
      #150a28;
  }

  .chat-date {
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.05);
    border-radius: 100px;
    padding: 4px 12px;
    align-self: center;
    margin-bottom: 0.75rem;
  }

  /* Par de mensagens */
  .chat-pair {
    display: contents;
  }

  /* ── Mensagem ── */
  .chat-msg {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    margin-bottom: 2px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  .chat-msg.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .chat-msg--out {
    flex-direction: row-reverse;
    margin-bottom: 12px;
  }

  .chat-msg--in { margin-bottom: 12px; }

  /* Avatar */
  .chat-avatar-wrap { flex-shrink: 0; }

  .chat-avatar {
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 50%;
    background: rgba(95,48,128,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1.5px solid rgba(167,139,250,0.3);
  }

  .chat-avatar__img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center top;
  }

  /* ── Bubble ── */
  .chat-bubble {
    max-width: 82%;
    padding: 10px 14px 8px;
    border-radius: 18px;
    font-size: 0.9375rem;
    line-height: 1.5;
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .chat-bubble p { margin: 0; }

  /* Saída (usuário) */
  .chat-bubble--out {
    background: linear-gradient(135deg, #5f3080, #3d1a5e);
    color: #fff;
    border-bottom-right-radius: 4px;
    font-weight: 600;
  }

  /* Entrada (Bella) */
  .chat-bubble--in {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.9);
    border-bottom-left-radius: 4px;
  }

  /* Meta (hora + check) */
  .chat-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    font-size: 0.625rem;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
    line-height: 1;
  }

  .chat-meta--in { justify-content: flex-start; }

  .chat-check { color: #a78bfa; }

  /* ── Typing bubble ── */
  .chat-bubble--typing {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.08);
    border-bottom-left-radius: 4px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .dot {
    width: 7px;
    height: 7px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
    animation: bounce 1.2s ease-in-out infinite;
  }

  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* ── Input bar decorativo ── */
  .chat-input-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .chat-input-fake {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 100px;
    padding: 10px 16px;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    text-decoration: none;
  }

  .chat-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.2s ease, filter 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .chat-send-btn:hover { transform: scale(1.1); filter: brightness(1.1); }
  .chat-send-btn:active { transform: scale(0.95); }
  .chat-send-btn svg { color: #fff; }

  @media (max-width: 480px) {
    .chat-bubble { font-size: 0.875rem; max-width: 88%; }
    .chat-window { border-radius: 20px; }
  }
</style>
