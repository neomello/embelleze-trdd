---
interface Props {
  title: string;
  sub?: string;
  light?: boolean;
}

const { title, sub, light = false } = Astro.props;
---

<div class:list={['section-title', { 'section-title--light': light }]}>
  <h2 class="section-title__h">{title}</h2>
  {sub && <p class="section-title__sub">{sub}</p>}
</div>

<style>
  .section-title { text-align: center; margin-bottom: var(--spacing-lg); }
  .section-title__h { font-size: var(--font-size-2xl); color: var(--color-purple); }
  .section-title--light .section-title__h { color: var(--color-white); }
  .section-title__sub { color: #666; margin-top: var(--spacing-xs); }
  .section-title--light .section-title__sub { color: rgba(255,255,255,0.8); }
</style>
