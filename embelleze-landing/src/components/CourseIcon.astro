  "💅": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="M12 22a7 7 0 0 0 7-7V7a3 3 0 0 0-3-3H8a3 3 0 0 0-3 3v8a7 7 0 0 0 7 7Z"/><path d="M12 11V4"/></svg>`,
