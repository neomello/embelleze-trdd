  "💄": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M12 12V4"/></svg>`,
  "🖊️": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="m12 3 4 4L7.5 16.5 3.5 12.5 12 3Z"/><path d="m14 5 4 4"/><path d="m3.5 12.5 8 8"/></svg>`,
  "🌿": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="M11 20A7 7 0 0 1 11 6a7 7 0 0 1 11 6 7 7 0 0 1-7 7M11 20a7 7 0 0 0-7-7M11 20v-7M4 13a7 7 0 0 1 7-7"/></svg>`,
  "👑": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7Z"/></svg>`,
  "🔥": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="${className}"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3 1.07.56 2 1.56 2 3a2.5 2.5 0 0 1-2.5 2.5Z"/><path d="M15 7c-2.3-2.3-1.6-6-1.6-6C10 3 6 7 6 14a6 6 0 0 0 12 0c0-3.3-1.5-5.5-3-7Z"/></svg>`,
