---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from '../assets/brand/logo-embelleze.png';
---
<header class="header" id="main-header">
  <div class="header__container">
    <a href="/" class="header__logo">
      <Image src={logo} alt="Instituto Embelleze" class="header__logo-img" />
    </a>
    
    <nav class="header__nav">
      <ul class="header__menu">
        <li><a href="/" class="header__link">Início</a></li>
        <li><a href="/cursos" class="header__link">Cursos</a></li>
        <li><a href="/mapa" class="header__link header__link--map">
          <Icon name="lucide:map-pin" class="header__icon" />
          <span>Localização</span>
        </a></li>
        <li><a href="#faq" class="header__link">Dúvidas</a></li>
      </ul>
      <a href="https://wa.me/5562984836550?text=Olá!+Gostaria+de+saber+mais+sobre+os+cursos+do+Instituto+Embelleze+Trindade" class="header__cta">Falar com Bella</a>
    </nav>

    <button class="header__mobile-toggle" id="mobile-menu-toggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Overlay -->
  <div class="header__mobile-overlay" id="mobile-overlay">
    <nav class="header__mobile-nav">
      <a href="/" class="header__mobile-link">Início</a>
      <a href="/cursos" class="header__mobile-link">Cursos</a>
      <a href="/mapa" class="header__mobile-link">Localização</a>
      <a href="#faq" class="header__mobile-link">Dúvidas</a>
      <a href="https://wa.me/5562984836550?text=Olá!+Gostaria+de+saber+mais+sobre+os+cursos+do+Instituto+Embelleze+Trindade" class="header__mobile-cta">WhatsApp</a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const toggle = document.getElementById('mobile-menu-toggle');
  const overlay = document.getElementById('mobile-overlay');
  const mobileLinks = document.querySelectorAll('.header__mobile-link');

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('header--scrolled');
    } else {
      header?.classList.remove('header--scrolled');
    }
  });

  // Mobile menu
  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('active');
    overlay?.classList.toggle('active');
    document.body.classList.toggle('no-scroll');
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      toggle?.classList.remove('active');
      overlay?.classList.remove('active');
      document.body.classList.remove('no-scroll');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99999;
    padding: 2rem 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header--scrolled {
    padding: 1rem 0;
    background: rgba(13, 4, 22, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header__container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header__logo {
    position: relative;
    z-index: 10000;
  }

  .header__logo-img {
    height: 38px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .header__menu {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .header__link {
    color: var(--color-white);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: 700;
    transition: color 0.3s ease;
    opacity: 0.8;
  }

  .header__link--map {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__icon {
    width: 14px;
    height: 14px;
    color: var(--color-orange);
  }

  .header__link:hover {
    color: #fff;
  }

  .header__cta {
    background: #fff;
    color: #12071f;
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .header__cta:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
  }

  /* Mobile Toggle */
  .header__mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 100000;
  }

  .header__mobile-toggle span {
    width: 28px;
    height: 2px;
    background: #fff;
    transition: all 0.3s ease;
  }

  .header__mobile-toggle.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .header__mobile-toggle.active span:nth-child(2) { opacity: 0; }
  .header__mobile-toggle.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  /* Mobile Overlay */
  .header__mobile-overlay {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100vh;
    background: #0d0416; /* Fundo sólido infalível */
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .header__mobile-overlay.active {
    transform: translateX(0);
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .header__mobile-link {
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.04em;
  }

  .header__mobile-cta {
    margin-top: 2rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-orange);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .header__nav { display: none; }
    .header__mobile-toggle { display: flex; }
  }
</style>
