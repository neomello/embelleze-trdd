---
/**
 * LocalSEO.astro
 * Componente avançado de SEO Geo-Localizado.
 * Implementa JSON-LD e Meta Tags de localização para dominar a busca regional.
 */

const schema = {
  "@context": "https://schema.org",
  "@type": "VocationalSchool",
  "name": "Instituto Embelleze Trindade",
  "image": "https://embelleze-bella.online/brand/logo-embelleze.png",
  "@id": "https://embelleze-bella.online",
  "url": "https://embelleze-bella.online",
  "telephone": "+5562994813565",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Manoel Monteiro, 1691",
    "addressLocality": "Trindade",
    "addressRegion": "GO",
    "postalCode": "75380-000",
    "addressCountry": "BR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -16.6506,
    "longitude": -49.4913
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "16:00"
    }
  ],
  "sameAs": [
    "https://www.instagram.com/embellezetrindade/",
    "https://www.facebook.com/institutoembellezetrindade/"
  ],
  "areaServed": [
    { "@type": "City", "name": "Trindade" },
    { "@type": "City", "name": "Goianira" },
    { "@type": "City", "name": "Santa Bárbara de Goiás" },
    { "@type": "City", "name": "Campestre de Goiás" },
    { "@type": "City", "name": "Guapó" },
    { "@type": "City", "name": "Abadia de Goiás" },
    { "@type": "City", "name": "Goiânia" },
    { "@type": "City", "name": "Caturaí" }
  ]
};
---

<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

<!-- Geo Meta Tags -->
<meta name="geo.region" content="BR-GO" />
<meta name="geo.placename" content="Trindade" />
<meta name="geo.position" content="-16.6506;-49.4913" />
<meta name="ICBM" content="-16.6506, -49.4913" />

<!-- Local Keywords - Camadas: Ampla, Local e Regional -->
<meta name="keywords" content="curso de cabeleireiro, curso de barbeiro, curso de manicure e pedicure, curso de maquiagem profissional, curso de design de sobrancelhas, curso de design de cilios, curso de alongamento de unhas, curso de beleza perto de mim, escola de beleza, cursos profissionalizantes, curso de beleza em trindade, instituto embelleze trindade, curso de beleza em goianira, curso de beleza em santa barbara de goias, curso de beleza em guapo" />
