---
interface Props {
  code: string;
  label?: string;
}

const { code, label = 'Seu código de reserva' } = Astro.props;
---

<div class="ticket-card">
  <p class="ticket-card__label">{label}</p>
  <p class="ticket-card__code">{code}</p>
</div>

<style>
  .ticket-card {
    background: var(--color-white);
    border: 2px dashed var(--color-orange);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    text-align: center;
  }
  .ticket-card__label { font-size: var(--font-size-sm); color: #666; margin-bottom: 4px; }
  .ticket-card__code {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-orange);
    letter-spacing: 0.1em;
    user-select: all;
  }
</style>
