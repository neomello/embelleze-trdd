---
import { Image } from 'astro:assets';
import { getCourseWhatsAppLink } from '../lib/whatsapp';
import CourseIcon from './CourseIcon.astro';

// Importação das imagens mapeadas
import cabeleireiroImg from '../assets/cursos/cabeleireiro.jpg';
import barbeiroImg from '../assets/home/form-bg.jpg';
import manicureImg from '../assets/cursos/manicure.jpg';
import sombrancelhasImg from '../assets/cursos/sombrancelhas.jpg';
import depilacaoImg from '../assets/cursos/depilacao.jpg';
import maquiagemImg from '../assets/home/banner-hero-mobile.png';
import penteadosImg from '../assets/home/profissionais-mercado.jpg';

interface Props {
  id: string;
  name: string;
  description: string;
  ctaText: string;
  category: string;
  iconId?: string;
  duration?: string | null;
  frequency?: string | null;
  schedule?: string | null;
  confirmed?: boolean;
  isEcommerce?: boolean;
  loading?: "lazy" | "eager";
}

const {
  id,
  name,
  description,
  category,
  iconId = 'lucide:sparkles',
  duration,
  frequency,
  schedule,
  confirmed = false,
  isEcommerce = false,
  loading = "lazy",
} = Astro.props;

const imageMap = {
  cabeleireiro: cabeleireiroImg,
  barbeiro: barbeiroImg,
  manicure: manicureImg,
  cilios: sombrancelhasImg,
  "alongamento-unhas": manicureImg,
  maquiagem: maquiagemImg,
  sobrancelhas: sombrancelhasImg,
  depilacao: depilacaoImg,
  penteados: penteadosImg,
};

const courseImage = imageMap[id as keyof typeof imageMap];
const link = getCourseWhatsAppLink(id, name);
const Element = isEcommerce ? 'div' : 'a';
---

<Element 
  href={!isEcommerce ? link : undefined} 
  class="course-card" 
  target={!isEcommerce ? "_blank" : undefined} 
  rel={!isEcommerce ? "noopener" : undefined} 
  data-course={id} 
  data-category={category}
  onclick={isEcommerce ? `addToCart('${id}', '${name}')` : undefined}
>
  <div class="course-card__glow"></div>
  
  {courseImage && (
    <div class="course-card__bg">
      <Image src={courseImage} alt="" class="course-card__bg-img" loading={loading} />
      <div class="course-card__overlay"></div>
    </div>
  )}
  
  <div class="course-card__header">
    <div class="course-card__icon-wrapper">
      <CourseIcon iconId={iconId} className="course-card__icon-svg" />
    </div>
    <div class="course-card__badges">
      {confirmed && <span class="course-card__badge course-card__badge--confirmed">Turma Confirmada</span>}
      <span class="course-card__badge course-card__badge--category">{category}</span>
    </div>
  </div>

  <div class="course-card__content">
    <h3 class="course-card__name">{name}</h3>
    <p class="course-card__desc">{description}</p>
  </div>

  <div class="course-card__footer">
    {duration && (
      <div class="course-card__meta">
        <div class="course-card__meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{duration}</span>
        </div>
        {frequency && (
          <div class="course-card__meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>{frequency}</span>
          </div>
        )}
        {schedule && (
          <div class="course-card__meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
               <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
            </svg>
            <span>{schedule}</span>
          </div>
        )}
      </div>
    )}
    
    {!confirmed && (
      <div class="course-card__pending">
        Consultar horários disponíveis
      </div>
    )}

    <div class="course-card__cta">
      <span>Saiba mais</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </div>
  </div>
</Element>

<style>
  .course-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px) saturate(200%);
    -webkit-backdrop-filter: blur(10px) saturate(200%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 12px 16px;
    cursor: pointer;
    text-decoration: none;
    color: #fff;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    height: 100%;
    width: 100%;
    gap: 12px;
  }

  .course-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: inherit;
    background: #12071f;
  }

  .course-card__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1);
    opacity: 0.03;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.6s;
  }



  .course-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-purple) 0%, var(--color-bg) 100%);
    mix-blend-mode: color;
    z-index: 1;
  }

  .course-card__overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 10%, rgba(18, 7, 31, 0.95) 100%);
    z-index: 2;
  }

  @media (min-width: 768px) {
    .course-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 2rem;
      border-radius: 28px;
    }
  }

  .course-card:active {
    transform: scale(0.96);
    background: rgba(255, 255, 255, 0.08);
  }



  .course-card__header {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .course-card__header {
      width: 100%;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }
  }

  .course-card__icon-wrapper {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-orange);
  }

  @media (min-width: 768px) {
    .course-card__icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: 12px;
    }
  }

  .course-card__icon-svg {
    width: 24px;
    height: 24px;
    stroke-width: 2;
  }

  .course-card__badges {
    display: none;
  }

  @media (min-width: 768px) {
    .course-card__badges {
      display: flex;
    }
  }

  .course-card__badge {
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .course-card__badge--confirmed {
    background: #00ff7f;
    color: #000;
  }

  .course-card__badge--category {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.8);
  }

  .course-card__content {
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .course-card__name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (min-width: 768px) {
    .course-card__name {
      font-size: 1.375rem;
      margin-bottom: 0.75rem;
      white-space: normal;
    }
  }

  .course-card__desc,
  .course-card__footer {
    display: none;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .course-card__desc,
    .course-card__footer {
      display: flex;
    }
  }

  .course-card__meta {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .course-card__meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 600;
  }

  .course-card__meta-item svg {
    width: 12px;
    height: 12px;
    color: var(--color-orange);
    opacity: 0.8;
  }

  .course-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.75rem;
    color: #fff;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .course-card__cta svg {
    width: 14px;
    height: 14px;
  }

  .course-card__cta:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    box-shadow: 0 4px 12px rgba(222, 88, 61, 0.3);
  }
</style>
