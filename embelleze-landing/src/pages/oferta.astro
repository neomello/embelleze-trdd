---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWhatsAppLink } from '../lib/whatsapp';
import courses from '../content/courses.json';
import CourseIcon from '../components/CourseIcon.astro';
import symbol from '../assets/brand/e.png';

const courseId = Astro.url.searchParams.get('curso') ?? '';
const utmSource = Astro.url.searchParams.get('utm_source') ?? '';

const course = courses.find(c => c.id === courseId);
const courseName = course?.name ?? 'nossos cursos';

const whatsappLink = getWhatsAppLink({
  course: courseName,
  origin: `oferta${utmSource ? `-${utmSource}` : ''}`,
});
---

<BaseLayout
  title={`${courseName} — Instituto Embelleze Trindade`}
  description={course?.description ?? 'Cursos profissionalizantes na área da beleza em Trindade/GO.'}
>
  <main class="oferta">
    <!-- Fundo Atmosférico -->
    <div class="oferta__bg"></div>

    <div class="oferta__container">
      <div class="oferta__card">
        <header class="oferta__header">
          <div class="oferta__badge">Oferta Exclusiva</div>
        </header>

        <div class="oferta__content">
          {course ? (
            <div class="oferta__course">
              <div class="oferta__icon-container">
                <CourseIcon iconId={course.iconId} className="oferta__icon-svg" />
              </div>
              <h1 class="oferta__title">{course.name}</h1>
              <p class="oferta__description">{course.description}</p>
            </div>
          ) : (
            <div class="oferta__generic">
              <h1 class="oferta__title">Transforme sua carreira na beleza</h1>
              <p class="oferta__description">Escolha um de nossos cursos profissionais e comece a faturar agora.</p>
            </div>
          )}
        </div>

        <div class="oferta__actions">
          <a href={whatsappLink} class="oferta__btn oferta__btn--primary">
             Reservar minha vaga no WhatsApp
          </a>
          <a href="/" class="oferta__btn oferta__btn--secondary">
            Conhecer todos os cursos
          </a>
        </div>

        <footer class="oferta__footer">
          <div class="oferta__location">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Trindade/GO</span>
          </div>
        </footer>
      </div>
    </div>

    <!-- Elementos Flutuantes -->
    <div class="oferta__floating-e">
      <Image src={symbol} alt="E" />
    </div>
  </main>
</BaseLayout>

<style>
  .oferta {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(7rem, 14vw, 10rem) var(--spacing-sm) clamp(1rem, 5vw, 4rem);
    background: #12071f;
    position: relative;
    overflow: hidden;
  }

  .oferta__bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 10% 20%, rgba(95, 48, 128, 0.2), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(222, 88, 61, 0.15), transparent 40%);
    z-index: 1;
  }

  .oferta__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
  }

  .oferta__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 600px;
  }

  .oferta__card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 40px;
    padding: clamp(2rem, 8vw, 4rem);
    text-align: center;
    box-shadow: 0 50px 100px rgba(0,0,0,0.5);
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slide-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .oferta__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .oferta__logo {
    height: 32px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .oferta__badge {
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 6px 16px;
    background: var(--color-orange);
    color: #fff;
    border-radius: 100px;
    box-shadow: 0 4px 15px rgba(222, 88, 61, 0.3);
  }

  .oferta__icon-container {
    width: 100px;
    height: 100px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .oferta__icon-svg {
    width: 50px;
    height: 50px;
    color: var(--color-orange);
    stroke-width: 1.5;
  }

  .oferta__title {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .oferta__description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 3.5rem;
    max-width: 90%;
    margin-left: auto;
    margin-right: auto;
  }

  .oferta__actions {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .oferta__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px 32px;
    border-radius: 24px;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .oferta__btn--primary {
    background: linear-gradient(135deg, var(--color-purple) 0%, #7e4db0 100%);
    color: #fff;
    box-shadow: 0 15px 35px rgba(95, 48, 128, 0.3);
  }

  .oferta__btn--primary:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 25px 50px rgba(95, 48, 128, 0.4);
  }

  .oferta__btn--secondary {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .oferta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .oferta__footer {
    display: flex;
    justify-content: center;
    opacity: 0.4;
  }

  .oferta__location {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }

  .oferta__location svg {
    width: 14px;
    height: 14px;
  }

  .oferta__floating-e {
    position: absolute;
    top: 10%;
    right: 5%;
    width: 140px;
    height: 140px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border-radius: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    animation: float 8s ease-in-out infinite;
  }

  .oferta__floating-e img {
    height: 70px;
    opacity: 0.5;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(15px, -20px) rotate(5deg); }
    66% { transform: translate(-10px, 10px) rotate(-3deg); }
  }

  @media (max-width: 500px) {
    .oferta__card { padding: 3rem 1.5rem; border-radius: 32px; }
    .oferta__title { font-size: 2.25rem; }
    .oferta__description { font-size: 1.125rem; }
    .oferta__floating-e { width: 80px; height: 80px; }
    .oferta__floating-e img { height: 40px; }
  }
</style>
