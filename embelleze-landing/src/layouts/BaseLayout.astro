---
import '../styles/global.css';
import '../styles/animations.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrackingPixel from '../components/TrackingPixel.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Instituto Embelleze Trindade',
  description = 'Cursos profissionalizantes na área da beleza em Trindade/GO. Fale com a Bella e comece sua nova profissão.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon-32x32.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <TrackingPixel />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />

    <script is:inline>
      // Global Lead Capture Interceptor
      window.addEventListener('click', async (e) => {
        const target = e.target.closest('a[href*="wa.me"]');
        if (!target) return;

        let phone = localStorage.getItem('sim_phone');
        const isFromSimulator = !!phone;
        
        // Se não temos o telefone (Lead NOVO), poderíamos pedir aqui.
        // Mas para não quebrar o fluxo (UX), vamos priorizar o Simulador.
        // Se o lead já passou pelo simulador, atualizamos para INTERESSADO.
        if (phone) {
          fetch('/api/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              phone: phone,
              status: 'INTERESSADO',
              last_message: `Conversão via clique: ${target.innerText || 'Botão WhatsApp'}`
            })
          }).catch(() => {});
        }
      });
    </script>
  </body>
</html>
